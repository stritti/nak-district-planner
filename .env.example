# PostgreSQL
POSTGRES_USER=nak
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nak_planner
POSTGRES_PORT=5432

# SQLAlchemy async connection string
# localhost → direkt auf dem Host ("uv run uvicorn", Option B)
# Docker Compose überschreibt diese URL für die Container automatisch
# via docker-compose.override.yml (Hostname "db").
DATABASE_URL=postgresql+asyncpg://nak:changeme@localhost:5432/nak_planner

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# !!! MUST be changed for production — the production_guard() startup check
#     will refuse to start with placeholder values.
SECRET_KEY=replace-with-a-long-random-secret-key

# Environment: development | production | staging
# Production guard validates all secrets/placeholders when APP_ENV=production.
APP_ENV=development

# OIDC Configuration (provider-agnostic)
# OIDC Discovery URL — example for Keycloak:
# https://keycloak.example.com/realms/nak-planner/.well-known/openid-configuration
# Production guard requires HTTPS and a non-default value.
OIDC_DISCOVERY_URL=https://oidc.example.com/.well-known/openid-configuration

# OIDC Client Credentials
# Production guard rejects placeholder values.
OIDC_CLIENT_ID=replace-with-oidc-client-id
OIDC_CLIENT_SECRET=replace-with-oidc-client-secret

# OIDC Issuer (extracted from discovery, can override if needed)
# OIDC_ISSUER=https://oidc.example.com

# OIDC Scopes (space-separated)
OIDC_SCOPES=openid profile email

# Optional: force a specific OIDC subject as superadmin
# If unset, the very first user that logs in becomes superadmin automatically.
# SUPERADMIN_SUB=<oidc-sub>

# Optional: IDP provisioning webhook (create/invite user at approval time)
# Enable only when a secure backend endpoint is available.
# IDP_PROVISIONING_ENABLED=false
# IDP_PROVISIONING_PROVIDER=webhook  # webhook | keycloak
# IDP_PROVISIONING_ENDPOINT=https://idp-admin.example.com/api/provision-user
# IDP_PROVISIONING_API_KEY=replace-with-provisioning-api-key
# IDP_PROVISIONING_TIMEOUT_SECONDS=10

# Optional: direct Keycloak admin provisioning (create user + invite email)
# IDP_PROVISIONING_PROVIDER=keycloak
# IDP_PROVISIONING_KEYCLOAK_BASE_URL=http://localhost:8080
# IDP_PROVISIONING_KEYCLOAK_REALM=nak-planner
# IDP_PROVISIONING_KEYCLOAK_ADMIN_USERNAME=admin
# IDP_PROVISIONING_KEYCLOAK_ADMIN_PASSWORD=replace-with-admin-password
# IDP_PROVISIONING_KEYCLOAK_INVITE_ON_APPROVAL=true

# Optional (dev/testing): trigger draft-service pre-generation once on backend startup
# STARTUP_GENERATE_DRAFT_SERVICES=true

# Self-Update Configuration
# UPDATE_MODE determines how system updates are triggered:
#   "manual"        — show shell commands to run on the server (default, safe)
#   "docker-socket" — automatic pull & restart via Docker socket mount
# UPDATE_MODE=manual
# DOCKER_COMPOSE_DIR=/opt/nak-district-planner

# GitHub Container Registry settings for version checks
# GHCR_OWNER=stritti
# GHCR_REPO=nak-district-planner

# Frontend OIDC Configuration
VITE_OIDC_DISCOVERY_URL=https://oidc.example.com/.well-known/openid-configuration
VITE_OIDC_CLIENT_ID=replace-with-oidc-client-id
