# PostgreSQL
POSTGRES_USER=nak
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nak_planner

# SQLAlchemy async connection string
# localhost → direkt auf dem Host ("uv run uvicorn", Option B)
# Docker Compose überschreibt diese URLs für die Container automatisch
# via docker-compose.override.yml (Hostname "db" / "redis").
DATABASE_URL=postgresql+asyncpg://nak:changeme@localhost:5432/nak_planner

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret-key

# Environment: development | production
APP_ENV=development

# API Key for X-API-Key header guard — generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=replace-with-a-random-api-key

# Frontend (Vite) — expose the same API key to the browser dev server
VITE_API_KEY=replace-with-a-random-api-key
