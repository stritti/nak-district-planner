# Lokale Entwicklung (ohne Docker)
# Kopieren: cp .env.example .env.local

# OIDC Configuration (provider-agnostic)
# OIDC Discovery URL — must match backend VITE_OIDC_DISCOVERY_URL
VITE_OIDC_DISCOVERY_URL=https://oidc.example.com/.well-known/openid-configuration

# OIDC Client ID (must match backend OIDC_CLIENT_ID)
VITE_OIDC_CLIENT_ID=replace-with-oidc-client-id

# Frontend Redirect URI (callback after OIDC login)
# In development: http://localhost:5173/auth/callback
# In production: https://yourdomain.com/auth/callback
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
