# Lokale Entwicklung (ohne Docker)
# Kopieren: cp .env.example .env.local

# OIDC Configuration (provider-agnostic)
# All OIDC config is now fetched at runtime via backend proxy (/api/v1/auth/oidc/discovery).
# No VITE_OIDC_* build-time env vars are needed.
#
# The discovery endpoint returns authorization_endpoint, token_endpoint, client_id, etc.
# Redirect URI is computed from window.location.origin + '/auth/callback'.
# Scope defaults to 'openid profile email' (override via VITE_OIDC_SCOPE if needed).
