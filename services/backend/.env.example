# Lokale Entwicklung (ohne Docker)
# Kopieren: cp .env.example .env

DATABASE_URL=postgresql+asyncpg://nak:changeme@localhost:5432/nak_planner
SECRET_KEY=replace-with-a-long-random-secret-key
API_KEY=replace-with-a-random-api-key
APP_ENV=development

# OpenTelemetry (optional)
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=nak-district-planner-backend
# OTEL_ENDPOINT=http://localhost:4318

# OIDC / Authentication
OIDC_DISCOVERY_URL=http://localhost:8080/auth/realms/nak/.well-known/openid-configuration
OIDC_CLIENT_ID=nak-planner
OIDC_CLIENT_SECRET=replace-with-actual-client-secret
# Optional: force a specific OIDC subject as superadmin
# SUPERADMIN_SUB=<oidc-sub>

# Optional: IDP provisioning webhook for approval flow
# IDP_PROVISIONING_ENABLED=false
# IDP_PROVISIONING_PROVIDER=webhook  # webhook | keycloak
# IDP_PROVISIONING_ENDPOINT=https://idp-admin.example.com/api/provision-user
# IDP_PROVISIONING_API_KEY=replace-with-provisioning-api-key
# IDP_PROVISIONING_TIMEOUT_SECONDS=10

# Optional: direct Keycloak admin provisioning (create user + invite email)
# IDP_PROVISIONING_PROVIDER=keycloak
# IDP_PROVISIONING_KEYCLOAK_BASE_URL=http://localhost:8080
# IDP_PROVISIONING_KEYCLOAK_REALM=nak-planner
# IDP_PROVISIONING_KEYCLOAK_ADMIN_USERNAME=admin
# IDP_PROVISIONING_KEYCLOAK_ADMIN_PASSWORD=replace-with-admin-password
# IDP_PROVISIONING_KEYCLOAK_INVITE_ON_APPROVAL=true
