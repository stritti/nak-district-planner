# Authentik Development Configuration

# Database Configuration
AUTHENTIK_POSTGRES_NAME=authentik
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_PASSWORD=authentik_dev_pw

# Secret Key (generate with: openssl rand -base64 32)
# CHANGE THIS IN PRODUCTION!
AUTHENTIK_SECRET_KEY=InsecureSecretKeyChangeInProduction

# Hostname (used for OIDC discovery)
# For local development: localhost:9000
# For production: auth.example.com
AUTHENTIK_HOSTNAME=localhost:9000

# Logging Level (debug, info, warning, error)
AUTHENTIK_LOG_LEVEL=info
