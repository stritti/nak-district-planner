# Keycloak Development Configuration

# Database Configuration
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=75992da5f756bc96

# Admin Account (change in production!)
