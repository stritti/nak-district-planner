# Keycloak Development Configuration

# Database Configuration
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_dev_pw

# Admin Account (change in production!)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin_dev_pw

# Hostname (used for OIDC discovery)
# For local development, this can be localhost
# For production, set to your domain: auth.example.com
KC_HOSTNAME=keycloak.localhost

# Logging Level (debug, info, warn, error)
KC_LOG_LEVEL=info
